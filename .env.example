# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address used to send booking emails.
# Must be on a domain you have verified with Resend.
# For first-time testing you can use the Resend onboarding address: onboarding@resend.dev
CONTACT_FROM_EMAIL="Rauhan Village <booking@yourdomain.com>"

# Address that receives booking enquiries
CONTACT_TO_EMAIL=rauhanvillage@gmail.com
